<% layout("layouts/boilerplate")%>

<div class="row">
    <div class="col-8 offset-2">

    <br>
        <h3>Create a New Listing</h3>
        <br>
    <form method="POST" action="/listings" novalidate class="needs-validation">
        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required>
        </div>
       <br>

        <div  class="mb-3">
       <label for="title" class="form-label">Description</label>
        <textarea name="listing[description]" placeholder="enter description" type="text" class="form-control" required></textarea>
        </div>
        <br>
    
        <div  class="mb-3">
        <label for="title" class="form-label">Image Link</label>
        <input name="listing[image]" placeholder="enter image URL/Link" type="text" class="form-control">
        </div>
       <br>


       <div class="row">
        <div  class="mb-3 col-md-4">
        <label for="title" class="form-label">Price</label>
        <input name="listing[price]" placeholder="enter price" type="number" class="form-control" required>
        </div>
       <br>

        <div  class="mb-3 col-md-8">
        <label for="title" class="form-label">Country</label>
        <input name="listing[country]" placeholder="enter country" type="text" class="form-control" required>
        </div>
       <br>

       </div>
        <div  class="mb-3">
         <label for="title" class="form-label">Location</label>
        <input name="listing[location]" placeholder="enter location" type="text" class="form-control" required>
        </div>
       <br>

        <button class="btn btn-dark add-btn">ADD</button>

      <br><br>
    </form>
</div>
</div>
