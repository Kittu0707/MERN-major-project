<% layout("layouts/boilerplate")%>

   <div class="row">
    <div class="col-8 offset-2">
        
    <h3 class="topp mt-4">Listing Details:</h3>

    <!-- <%= listing%> -->
<br>
  <div class="card col-6 offset-2 show-card" >
  <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text heading"><br>
        <%= listing.title%><br>
        </p>
       <p class=> <b>DESCRIPTION:</b> &nbsp; &nbsp; <%= listing.description%><br>
     <b>  PRICE:</b> &nbsp;&nbsp; &#8377; <%= listing.price.toLocaleString("en-IN")%><br>
      <b> LOCATION:</b> &nbsp; &nbsp; <%= listing.location%><br>
       <b> COUNTRY:</b>  &nbsp;&nbsp; <%= listing.country%><br></p>
    
  </div>
</div>

<br>


    <div class="btns ">
    <a href="/listings/<%= listing._id%>/edit " class="btn btn-dark col-1 offset-2 edit-btn ">Edit</a>
    
   
    <form method="POST" action="/listings/<%= listing._id%>?_method=DELETE">
     <button class="btn btn-dark offset-4 del-btn">Delete</button>

      </div>
<br>
    </form>
</div>
</div>